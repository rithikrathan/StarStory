// =====================================================================
//  STAR STORY — Player State Machine DOT Graphs
//  5 progressive phases building from 5 states → 25 states
//  Render with:  dot -Tpng plans.dot -o plans.png
//  Render single phase:  csplit plans.dot '/^\/\/ ===/' '{*}' -f phase
//                        dot -Tpng phase00 -o phase1.png
// =====================================================================



// ========================= PHASE 1 =========================
// Core Foundation — 5 states
// Idle, Walk, Run, Ascend, Fall

digraph phase1 {
    rankdir=TB; splines=ortho; nodesep=0.5; ranksep=0.6;
    node [shape=box, style=rounded, width=1.4, height=0.5, fontname="monospace"];
    edge [fontname="monospace", fontsize=10];

    subgraph cluster_ground {
        label="Ground"; style=dashed; color=gray;
        { rank=same; Idle; Walk; Run; }
    }
    subgraph cluster_air {
        label="Air"; style=dashed; color=gray;
        Ascend; Fall;
    }

    Idle  -> Walk  [dir=both, label="input>0 / input=0"];
    Walk  -> Run   [dir=both, label="sprint / release"];
    Run   -> Idle  [label="input=0"];
    Idle  -> Ascend [label="jump"];
    Walk  -> Ascend [label="jump"];
    Run   -> Ascend [label="jump"];
    Ascend -> Fall  [label="vel.y<0"];
    Fall  -> Idle   [label="land"];
}



// ========================= PHASE 2 =========================
// Starts, Stops & Game Feel — +6 states = 11 total
// Adds: Start_Walk, Start_Run, Stop_Walk, Stop_Run, Jump_Windup, Land

digraph phase2 {
    rankdir=TB; splines=ortho; nodesep=0.5; ranksep=0.6;
    node [shape=box, style=rounded, width=1.4, height=0.5, fontname="monospace"];
    edge [fontname="monospace", fontsize=9];

    subgraph cluster_ground {
        label="Ground"; style=dashed; color=gray;
        { rank=same; Idle; Start_Walk; Walk; }
        { rank=same; Stop_Walk; Start_Run; }
        { rank=same; Stop_Run; }
        Land;
    }
    subgraph cluster_air {
        label="Air"; style=dashed; color=gray;
        Jump_Windup; Ascend; Fall;
    }

    Idle       -> Start_Walk [label="input>0"];
    Start_Walk -> Walk       [label="anim end"];
    Walk       -> Stop_Walk  [label="input=0"];
    Stop_Walk  -> Idle       [label="anim end"];

    Idle       -> Start_Run  [label="sprint+input"];
    Start_Run  -> Run        [label="anim end"];

    Walk       -> Run        [label="sprint"];
    Run        -> Walk       [label="release"];
    Run        -> Stop_Run   [label="input=0"];
    Stop_Run   -> Idle       [label="anim end"];

    Idle       -> Jump_Windup [label="jump"];
    Walk       -> Jump_Windup [label="jump"];
    Run        -> Jump_Windup [label="jump"];
    Jump_Windup -> Ascend     [label="anim end"];

    Ascend     -> Fall        [label="vel.y<0"];
    Fall       -> Jump_Windup [label="coyote time"];
    Fall       -> Land        [label="land"];
    Land       -> Idle        [label="input=0"];
    Land       -> Walk        [label="input>0"];
}



// ========================= PHASE 3 =========================
// Momentum & Advanced Physics — +7 states = 18 total
// Adds: Sprint, Stop_Sprint, Pivot_Run, Pivot_Sprint, Apex, Land_Soft, Land_Heavy

digraph phase3 {
    rankdir=TB; splines=ortho; nodesep=0.5; ranksep=0.6;
    node [shape=box, style=rounded, width=1.4, height=0.5, fontname="monospace"];
    edge [fontname="monospace", fontsize=9];

    subgraph cluster_ground {
        label="Ground"; style=dashed; color=gray;
        { rank=same; Idle; Start_Walk; Walk; Stop_Walk; }
        { rank=same; Start_Run; Run; Stop_Run; }
        { rank=same; Sprint; Stop_Sprint; }
        Pivot_Run; Pivot_Sprint;
        Land_Soft; Land_Heavy;
    }
    subgraph cluster_air {
        label="Air"; style=dashed; color=gray;
        Jump_Windup; Ascend; Apex; Fall;
    }

    Idle       -> Start_Walk  [label="input>0"];
    Start_Walk -> Walk        [label="anim end"];
    Walk       -> Stop_Walk   [label="input=0"];
    Stop_Walk  -> Idle        [label="anim end"];
    Idle       -> Start_Run   [label="sprint+input"];
    Start_Run  -> Run         [label="anim end"];

    Walk       -> Run         [label="sprint"];
    Run        -> Walk        [label="release"];
    Run        -> Stop_Run    [label="input=0"];
    Stop_Run   -> Idle        [label="anim end"];
    Run        -> Sprint      [label="sprint"];
    Sprint     -> Run         [label="release"];
    Sprint     -> Stop_Sprint [label="input=0"];
    Stop_Sprint -> Idle       [label="anim end"];

    Run        -> Pivot_Run   [label="180° input"];
    Pivot_Run  -> Run         [label="anim end"];
    Sprint     -> Pivot_Sprint [label="180° input"];
    Pivot_Sprint -> Sprint    [label="anim end"];

    Walk       -> Fall        [label="!floor"];
    Run        -> Fall        [label="!floor"];
    Sprint     -> Fall        [label="!floor"];

    { Idle; Walk; Run; Sprint; } -> Jump_Windup [label="jump"];
    Jump_Windup -> Ascend      [label="anim end"];
    Ascend     -> Apex         [label="vel.y near 0"];
    Apex       -> Fall         [label="vel.y<0"];

    Fall       -> Land_Soft    [label="low fall"];
    Fall       -> Land_Heavy   [label="high fall"];
    Land_Soft  -> Idle         [label="input=0"];
    Land_Soft  -> Walk         [label="input>0"];
    Land_Heavy -> Idle         [label="input=0"];
    Land_Heavy -> Walk         [label="input>0"];
}



// ========================= PHASE 4 =========================
// Environment Hooks — +3 states = 21 total
// Adds: Ledge_Grab, Vault, Interact

digraph phase4 {
    rankdir=TB; splines=ortho; nodesep=0.5; ranksep=0.6;
    node [shape=box, style=rounded, width=1.4, height=0.5, fontname="monospace"];
    edge [fontname="monospace", fontsize=9];

    subgraph cluster_ground {
        label="Ground"; style=dashed; color=gray;
        { rank=same; Idle; Walk; Run; Sprint; }
    }
    subgraph cluster_air {
        label="Air"; style=dashed; color=gray;
        Fall;
    }
    subgraph cluster_action {
        label="Action"; style=dashed; color=gray;
        Ledge_Grab; Vault; Interact;
    }

    Fall       -> Ledge_Grab  [label="chest raycast"];
    Ledge_Grab -> Idle         [label="pull up"];
    Ledge_Grab -> Fall         [label="let go"];

    Run        -> Vault       [label="waist raycast"];
    Sprint     -> Vault       [label="waist raycast"];
    Vault      -> Run         [label="anim end"];
    Vault      -> Sprint      [label="anim end"];

    Idle       -> Interact    [label="context trigger"];
    Interact   -> Idle        [label="anim end"];
}



// ========================= PHASE 5 =========================
// Global Interrupts — +3 states = 24 total
// Adds: Stagger, Wounded_Idle, Wounded_Walk

digraph phase5 {
    rankdir=TB; splines=ortho; nodesep=0.5; ranksep=0.6;
    node [shape=box, style=rounded, width=1.4, height=0.5, fontname="monospace"];
    edge [fontname="monospace", fontsize=9];

    subgraph cluster_hurt {
        label="Hurt (Global)"; style=dashed; color=red;
        Stagger; Wounded_Idle; Wounded_Walk;
    }

    node [shape=plaintext, width=0, height=0];
    AnyState [label="[Any State]"];
    AnyState -> Stagger [label="damage taken", style=dashed, color=red];

    node [shape=box, style=rounded, width=1.4, height=0.5, color=red];
    Stagger -> Wounded_Idle [label="HP ≤ 25%"];
    Stagger -> Idle [label="HP > 25%", color=gray];
    Wounded_Idle -> Wounded_Walk [dir=both, label="input / input=0"];
    Wounded_Idle -> Idle [label="heal event", color=gray];
    Wounded_Walk -> Idle [label="heal event", color=gray];
}



// ========================= PHASE 6 =========================
// FINAL — All Phases Merged (25 states)

digraph final {
    rankdir=TB; splines=ortho; nodesep=0.4; ranksep=0.5;
    node [shape=box, style=rounded, width=1.3, height=0.4, fontname="monospace", fontsize=9];
    edge [fontname="monospace", fontsize=8];
    compound=true; newrank=true;

    subgraph cluster_ground {
        label="Ground"; style=dashed; color="#888";
        { rank=same; Idle; Start_Walk; Walk; Stop_Walk; }
        { rank=same; Start_Run; Run; Stop_Run; }
        { rank=same; Sprint; Stop_Sprint; }
        Pivot_Run; Pivot_Sprint;
        Land; Land_Soft; Land_Heavy;
    }
    subgraph cluster_air {
        label="Air"; style=dashed; color="#888";
        Jump_Windup; Ascend; Apex; Fall;
    }
    subgraph cluster_action {
        label="Action"; style=dashed; color="#888";
        Ledge_Grab; Vault; Interact;
    }
    subgraph cluster_hurt {
        label="Hurt (Global)"; style=dashed; color="red";
        Stagger; Wounded_Idle; Wounded_Walk;
    }

    Idle       -> Start_Walk  [label="input>0"];
    Start_Walk -> Walk        [label="anim end"];
    Walk       -> Stop_Walk   [label="input=0"];
    Stop_Walk  -> Idle        [label="anim end"];
    Idle       -> Start_Run   [label="sprint+input"];
    Start_Run  -> Run         [label="anim end"];
    Walk      -> Run          [label="sprint"];
    Run       -> Walk         [label="release"];
    Run       -> Stop_Run     [label="input=0"];
    Stop_Run  -> Idle         [label="anim end"];
    Run       -> Sprint       [label="sprint"];
    Sprint    -> Run          [label="release"];
    Sprint    -> Stop_Sprint  [label="input=0"];
    Stop_Sprint -> Idle       [label="anim end"];
    Run       -> Pivot_Run    [label="180°"];
    Pivot_Run -> Run          [label="anim end"];
    Sprint    -> Pivot_Sprint [label="180°"];
    Pivot_Sprint -> Sprint    [label="anim end"];

    { Idle; Walk; Run; Sprint; } -> Jump_Windup [label="jump"];
    Jump_Windup -> Ascend      [label="anim end"];
    Ascend     -> Apex         [label="vel.y≈0"];
    Apex       -> Fall         [label="vel.y<0"];
    { Walk; Run; Sprint; } -> Fall [label="!floor"];
    Fall       -> Jump_Windup  [label="coyote"];

    Fall       -> Land_Soft    [label="low"];
    Fall       -> Land_Heavy   [label="high"];
    Land_Soft  -> Idle         [label="input=0"];
    Land_Soft  -> Walk         [label="input>0"];
    Land_Heavy -> Idle         [label="input=0"];
    Land_Heavy -> Walk         [label="input>0"];

    Fall       -> Ledge_Grab   [label="chest hit"];
    Ledge_Grab -> Idle         [label="pull up"];
    Ledge_Grab -> Fall         [label="let go"];
    { Run; Sprint; } -> Vault  [label="waist hit"];
    Vault      -> Run          [label="anim end"];
    Vault      -> Sprint       [label="anim end"];
    Idle       -> Interact     [label="trigger"];
    Interact   -> Idle         [label="anim end"];

    node [color=red];
    edge [color=red, style=dashed];
    Stagger    -> Wounded_Idle [label="HP≤25%"];
    Stagger    -> Idle         [label="HP>25%", color=grey, style=solid];
    Wounded_Idle -> Wounded_Walk [dir=both, label="input toggle", style=solid];
    Wounded_Idle -> Idle       [label="heal", color=grey, style=solid];
    Wounded_Walk -> Idle       [label="heal", color=grey, style=solid];
}
